{
  "name": "dannyis-astro",
  "type": "module",
  "author": {
    "name": "Danny Smith",
    "email": "hi@danny.is",
    "url": "https://danny.is"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dannysmith/dannyis-astro.git"
  },
  "license": "See LICENSE.md",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "find public -name .DS_Store -delete 2>/dev/null || true",
    "build": "astro build",
    "postbuild": "rm -rf dist/.well-known && cp -R dist/well-known dist/.well-known",
    "preview": "astro preview",
    "vercel:config": "bun scripts/build-vercel-config.mjs --stdout",
    "sync": "astro sync",
    "audit:serve": "astro build --site http://localhost:4321 && astro preview",
    "audit": "bunx unlighthouse --site http://localhost:4321",
    "check:lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "check:format": "prettier --check .",
    "check:types": "tsc --noEmit && astro check",
    "check:knip": "knip",
    "check:dupes": "jscpd src",
    "check:all": "bun run check:types && bun run check:format && bun run check:lint && bun run test:all",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "playwright test",
    "test:all": "bun run test:unit && bun run test:e2e",
    "scrape-toolbox": "tsx scripts/get-toolbox-json.ts",
    "generate-og-image": "tsx scripts/generate-og-image.ts",
    "standard-site:publication": "tsx scripts/standard-site/create-publication.ts",
    "standard-site:sync": "tsx scripts/standard-site/sync-document.ts",
    "task:complete": "node scripts/complete-task.js"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/react": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@dannysmith/datepicker": "^0.1.6",
    "@fontsource-variable/fira-code": "^5.2.7",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.84",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^6.4.2",
    "astro-auto-import": "^0.5.1",
    "astro-embed": "^0.13.0",
    "astro-expressive-code": "^0.42.0",
    "astro-icon": "^1.1.5",
    "marked": "^18.0.4",
    "mdast-util-to-string": "^4.0.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-mermaid": "^3.0.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@atproto/api": "^0.20.9",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "astro-eslint-parser": "^1.4.0",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.7.0",
    "gray-matter": "^4.0.3",
    "jscpd": "^4.2.4",
    "knip": "^6.14.2",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.7"
  }
}
