---
import type { CollectionEntry } from 'astro:content';
import { BaseHead, Footer, LLMDiscoveryNote, MainNavigation, NoteCard } from '@components/layout/index';
import { MarkdownContentActions } from '@components/ui/index';
import { getDocumentUri } from '@utils/standard-site';

type Props = CollectionEntry<'notes'>['data'];

const { title, pubDate, description, sourceURL, tags, draft, styleguide } = Astro.props;

// Build OG image path for this note
const ogImage = `/notes/${Astro.params.slug}/og-image.png`;

// Root-relative URL of the raw markdown twin (served by [...slug].md.ts).
const markdownUrl = `${Astro.url.pathname.replace(/\/$/, '')}.md`;

// standard.site document AT-URI for the <head> verification link tag (null for
// drafts, styleguides, or posts before the configured cutoff).
const standardSiteDocumentUri =
  getDocumentUri('notes', Astro.params.slug!, { draft, styleguide, pubDate }) ?? undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      type="article"
      pageType="note"
      image={ogImage}
      pubDate={pubDate}
      tags={tags}
      standardSiteDocumentUri={standardSiteDocumentUri}
      markdownUrl={markdownUrl}
    />
  </head>

  <body>
    <MainNavigation />
    <main style={`--vt-name: note-${Astro.params.slug}`}>
      <LLMDiscoveryNote />
      <NoteCard
        title={title}
        pubDate={pubDate}
        sourceURL={sourceURL}
        tags={tags}
        slug={Astro.params.slug!}
      >
        <slot />
        <MarkdownContentActions markdownUrl={markdownUrl} />
      </NoteCard>
    </main>

    <Footer />

    <style>
      body {
        display: grid;
        grid-template-rows: auto min-content;
        grid-template-columns: 100%;
      }

      main {
        padding: var(--space-s);
        padding-block: var(--space-2xl);
        display: grid;
        place-items: center;

        .note {
          max-width: var(--measure-standard);
        }
      }
    </style>
  </body>
</html>
