---
import BaseLayout from '@layouts/BaseLayout.astro'
const posts = await Astro.glob('./writing/*.*') // returns an array of posts that live at ./src/pages/post/*.md
---

<BaseLayout title="Danny is Writing">
  <main>
    <h1>Writing</h1>
    <ul>
      {
        posts.reverse().map((post) => (
          <li>
            <a href={post.url}>{post.frontmatter.title}</a>
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>
