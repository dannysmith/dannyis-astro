---
/**
 * Scratchpad - A minimal page for testing vertical rhythm and spacing
 * Covers all the edge cases for prose spacing work.
 */
import { BaseHead, MainNavigation } from '@components/layout/index';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Scratchpad"
      description="Vertical rhythm testing"
      robotsDirective="noindex, nofollow"
    />
  </head>
  <body>
    <MainNavigation />
    <main>
      <h1>Test Page</h1>
    </main>
  </body>
</html>
<style>
  body {
    min-height: 100vh;
  }

  main {
    margin: 0 auto;
    padding: var(--space-m);
    max-width: 100ch;
  }
</style>
