---
import { BaseHead, Footer, MainNavigation } from '@components/layout/index';
import { Content as AiContent } from './_ai.md';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="AI Statement"
      description="How I use AI when writing, designing, and building this site — and where I don't."
      pageType="page"
    />
  </head>
  <body>
    <MainNavigation />
    <main class="content">
      <h1>AI Statement</h1>
      <AiContent />
    </main>
    <Footer />

    <style>
      .content {
        max-width: var(--measure-standard);
        margin-inline: auto;
        padding: var(--space-2xl) var(--space-s);
      }

      h1 {
        font-family: var(--font-display);
        font-size: var(--font-size-3xl);
        font-weight: var(--font-weight-extrabold);
        margin-bottom: var(--space-m);
        text-transform: uppercase;
        font-feature-settings: 'case' on;
        text-align: center;
      }
    </style>
  </body>
</html>
