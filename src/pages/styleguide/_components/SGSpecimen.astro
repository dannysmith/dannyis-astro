---
/**
 * SGSpecimen - the repeated documentation unit: "you write this" + what renders.
 *
 * Shows a source snippet (via Expressive Code) above the live rendered output
 * passed as the default slot. Used across the Content/UI component pages.
 *
 * Usage:
 *   <SGSpecimen code={`<Callout>Heads up</Callout>`} lang="mdx">
 *     <Callout>Heads up</Callout>
 *   </SGSpecimen>
 */
import { Code } from 'astro-expressive-code/components';

interface Props {
  /** Source the author would type, shown as a highlighted code block. */
  code: string;
  /** Expressive Code language. Defaults to MDX (most content examples). */
  lang?: string;
}

const { code, lang = 'mdx' } = Astro.props;
---

<div class="sg-specimen">
  <Code code={code} lang={lang} />
  <div class="sg-specimen-result">
    <slot />
  </div>
</div>

<style>
  .sg-specimen {
    display: grid;
    gap: var(--space-s);
  }

  .sg-specimen-result {
    padding: var(--space-m);
    border: var(--border-width-hairline) solid var(--color-border);
    border-radius: var(--radius-sm);
  }
</style>
