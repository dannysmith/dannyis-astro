---
/**
 * SGSwitcher - renders slot content across the site's typographic contexts.
 *
 * Successor to `SGTypographySwitcher`, trimmed to the four contexts we keep
 * (UI Flow dropped). Wraps the shared `<Tabs>` so there's one tab system on the
 * site. Use only where cross-context comparison earns it — many specimens only
 * make sense in a single context.
 *
 * Contexts (in tab order):
 * - Default (flow)     — `.flow` (prose defaults + vertical rhythm/spacing)
 * - Long form Prose    — `<LongFormProseTypography>`, as used in articles
 * - Default (no flow)  — bare, no wrapper
 * - UI Style           — `.ui-style` (spacing/most styles stripped)
 */
import { Tabs, TabItem } from '@components/mdx/index';
import { LongFormProseTypography } from '@components/layout/index';

type TypographySystem =
  | { name: string; type: 'none' }
  | { name: string; type: 'component'; component: 'LongFormProseTypography' }
  | { name: string; type: 'class'; className: string };

const typographySystems: TypographySystem[] = [
  { name: 'Default (flow)', type: 'class', className: 'flow' },
  { name: 'Long form Prose', type: 'component', component: 'LongFormProseTypography' },
  { name: 'Default (no flow)', type: 'none' },
  { name: 'UI Style', type: 'class', className: 'ui-style' },
];

const content = await Astro.slots.render('default');
---

<Tabs>
  {
    typographySystems.map((system) => (
      <TabItem label={system.name}>
        {system.type === 'none' && <Fragment set:html={content} />}
        {system.type === 'component' && system.component === 'LongFormProseTypography' && (
          <LongFormProseTypography>
            <Fragment set:html={content} />
          </LongFormProseTypography>
        )}
        {system.type === 'class' && <div class={system.className} set:html={content} />}
      </TabItem>
    ))
  }
</Tabs>
