---
/**
 * Design Tokens partial
 */

import { Tabs, TabItem } from '@components/mdx/index';

// Spacing scale tokens
const baseTokens = [
  { variable: '--space-3xs' },
  { variable: '--space-2xs' },
  { variable: '--space-xs' },
  { variable: '--space-s' },
  { variable: '--space-m' },
  { variable: '--space-l' },
  { variable: '--space-xl' },
  { variable: '--space-2xl' },
  { variable: '--space-3xl' },
];

const lineHeights = ['normal', 'loose', 'snug', 'tight', 'none'];
const letterSpacings = ['normal', 'tight', 'wide', 'wider'];
const fontWeights = [
  'light',
  'normal',
  'regular',
  'medium',
  'semibold',
  'bold',
  'extrabold',
  'heavy',
];
const borderWidths = ['hairline', 'base', 'thick', 'heavy', 'accent'];
const borderRadii = ['xs', 'sm', 'md', 'lg', 'full'];
const shadows = ['small', 'medium'];

// Font families mapped to the five usage contexts.
// Four CSS variables cover five contexts: --font-ui serves both UI elements AND short-form prose.
const fontFamilies = [
  {
    variable: '--font-display',
    family: 'Geist',
    context: '1. Display',
    usage:
      'Large, presentational type. Page titles, hero text, 404, brand marks. Mostly used as Caps.',
  },
  {
    variable: '--font-prose',
    family: 'Literata',
    context: '2. Long-form prose',
    usage:
      'Articles and any content inside .longform-prose. Rich typographic features for sustained reading.',
  },
  {
    variable: '--font-ui',
    family: 'Figtree',
    context: '3. Short-form prose + 4. UI',
    usage:
      'Document body default. Notes, /now, callouts, captions AND interface elements — navigation, buttons, pills, form controls.',
  },
  {
    variable: '--font-code',
    family: 'Fira Code',
    context: '5. Code',
    usage: 'Code blocks, inline code, and occasional stylistic monospace.',
  },
];

// Font sizes with typical usage
const fontSizes = [
  { variable: '--font-size-xs', usage: 'Captions, labels, fine print' },
  { variable: '--font-size-sm', usage: 'Secondary text, metadata, UI elements' },
  { variable: '--font-size-base', usage: 'Body text, paragraphs' },
  { variable: '--font-size-md', usage: 'Emphasized body text, lead paragraphs' },
  { variable: '--font-size-lg', usage: 'Section headings (h4), large UI text' },
  { variable: '--font-size-xl', usage: 'Subheadings (h3)' },
  { variable: '--font-size-2xl', usage: 'Major headings (h2)' },
  { variable: '--font-size-3xl', usage: 'Page titles (h1)' },
];
---

<section id="design-tokens" class="styleguide-section flow">
  <h2>Design Tokens</h2>
  <p>
    Spacing, typography, borders, and motion tokens that provide consistent rhythm and visual harmony
    across the site. All values use fluid scaling via <code>clamp()</code> for responsive behavior.
  </p>

<!-- Spacing Scale -->
<h3>Spacing Scale</h3>
<p>
  Generated using <a href="https://utopia.fyi/space/calculator">Utopia</a>. Base scale provides
  consistent spacing; fluid pairs smoothly interpolate between sizes based on viewport.
</p>

<table>
  <thead>
    <tr>
      <th>Token</th>
      <th>Visual Representation</th>
    </tr>
  </thead>
  <tbody>
    {
      baseTokens.map(({ variable }) => (
        <tr>
          <td>
            <code>{variable}</code>
          </td>
          <td>
            <div class="spacing-bar" style={`width: var(${variable})`} />
          </td>
        </tr>
      ))
    }
  </tbody>
</table>

<h3>Border Widths</h3>
<p>
  Use hairline for subtle dividers, base for standard borders, and heavier weights for emphasis or
  interactive states.
</p>
<table>
  <thead>
    <tr>
      <th>Variable</th>
      <th>Preview</th>
    </tr>
  </thead>
  <tbody>
    {
      borderWidths.map(name => (
        <tr>
          <td>
            <code>{`--border-width-${name}`}</code>
          </td>
          <td>
            <div class="border-width-preview" style={`border-bottom-width: var(--border-width-${name})`} />
          </td>
        </tr>
      ))
    }
  </tbody>
</table>

<h3>Border Radii</h3>
<p>
  From subtle rounding (xs) to fully circular (full). Use smaller radii for compact UI elements,
  larger for cards and containers.
</p>
<table>
  <thead>
    <tr>
      <th>Variable</th>
      <th>Preview</th>
    </tr>
  </thead>
  <tbody>
    {
      borderRadii.map(name => (
        <tr>
          <td>
            <code>{`--radius-${name}`}</code>
          </td>
          <td>
            <div class="border-radius-preview" style={`border-radius: var(--radius-${name})`} />
          </td>
        </tr>
      ))
    }
  </tbody>
</table>

<h3>Shadows</h3>
<p>
  Drop shadows for creating depth and elevation. Use sparingly to draw attention to raised elements.
</p>
<table>
  <thead>
    <tr>
      <th>Variable</th>
      <th>Preview</th>
    </tr>
  </thead>
  <tbody>
    {
      shadows.map(name => (
        <tr>
          <td>
            <code>{`--shadow-${name}`}</code>
          </td>
          <td class="shadow-preview-container">
            <div class="shadow-preview" style={`filter: var(--shadow-${name})`} />
          </td>
        </tr>
      ))
    }
  </tbody>
</table>

<!-- Typography Tokens -->

<h3>Font Families</h3>
<p>
  Typography on this site serves five distinct usage contexts, covered by four font stacks.
  Short-form prose and UI elements share <code>--font-ui</code> (Figtree) — so "Notes" body copy
  and a button label are set in the same face at different scales. Long-form articles are scoped
  to Literata via <code>.longform-prose</code>; everything else inherits <code>--font-ui</code> as
  the document body default.
</p>
{
  fontFamilies.map(({ family, variable, context, usage }) => (
    <div class="sg-panel">
      <p class="font-preview" style={`font-family: var(${variable})`}>
        The quick brown fox jumps over the lazy dog
      </p>
      <p class="font-meta">
        <strong>{family}</strong> · <code>{variable}</code> · <em>{context}</em>
        <br />
        {usage}
      </p>
    </div>
  ))
}

<h3>Font Sizes</h3>
<p>Fluid type scale using <a href="https://utopia.fyi/type/calculator">Utopia</a>.</p>
<table>
  <thead>
    <tr>
      <th>Preview</th>
      <th>Variable</th>
      <th>Typical Usage</th>
    </tr>
  </thead>
  <tbody>
    {
      fontSizes.map(({ variable, usage }) => (
        <tr>
          <td class="font-size-preview" style={`font-size: var(${variable})`}>
            Aa
          </td>
          <td>
            <code>{variable}</code>
          </td>
          <td>{usage}</td>
        </tr>
      ))
    }
  </tbody>
</table>

<h4>Line Height</h4>
<p>
  Line height can be controlled via the <code>--leading-*</code> CSS variables. The default is <code
    >var(--leading-normal)</code
  >.
</p>
<Tabs>
  {
    lineHeights.map(name => (
      <TabItem label={name}>
        <p style={`line-height: var(--leading-${name})`}>
          Hello there this is a line of text to show the line height. Lorem ipsum dolor sit amet
          consectetur adipisicing elit. Quisquam, quos. Lorem ipsum dolor sit amet consectetur
          adipisicing elit. Quisquam, quos. Lorem ipsum dolor sit amet consectetur adipisicing elit.
          Quisquam, quos. Lorem ipsum dolor sit amet consectetur adipisicing elit. Quisquam, quos.
          Lorem ipsum dolor sit amet consectetur adipisicing elit. Quisquam, quos.
        </p>
      </TabItem>
    ))
  }
</Tabs>

<h4>Letter Spacing</h4>
<p>
  Letter spacing can be controlled via the <code>--tracking-*</code> CSS variables. The default is <code
    >var(--tracking-normal)</code
  >.
</p>
<Tabs>
  {
    letterSpacings.map(name => (
      <TabItem label={name}>
        <p class="letter-spacing-preview" style={`letter-spacing: var(--tracking-${name})`}>
          Hello there this is a line of text to show the letter spacing.
        </p>
      </TabItem>
    ))
  }
</Tabs>

<h3>Font Weights</h3>
<p>
  All four families are variable fonts. Exact weight range depends on the face (Geist 100–900,
  Figtree 300–900, Literata 200–900, Fira Code 300–700). These tokens provide common stops — use
  intermediate values when a design calls for it.
</p>
<table>
  <thead>
    <tr>
      <th>Preview</th>
      <th>Variable</th>
    </tr>
  </thead>
  <tbody>
    {
      fontWeights.map(name => (
        <tr>
          <td class="font-weight-preview" style={`font-weight: var(--font-weight-${name})`}>
            Aa
          </td>
          <td>
            <code>{`--font-weight-${name}`}</code>
          </td>
        </tr>
      ))
    }
  </tbody>
</table>
</section>

<style>
  /* Spacing scale */
  .spacing-bar {
    height: var(--space-s);
    background-color: var(--color-accent);
    border-radius: var(--radius-xs);
  }

  /* Border widths table */
  .border-width-preview {
    border-bottom-style: solid;
    border-bottom-color: var(--color-accent);
  }

  /* Border radii table */
  .border-radius-preview {
    width: 4rem;
    height: 4rem;
    background-color: var(--color-accent);
    border-radius: var(--radius-full);
  }

  /* Shadows table */
  .shadow-preview-container {
    background-color: var(--color-background);
    padding: var(--space-2xs);
  }
  .shadow-preview {
    width: 4rem;
    height: 4rem;
    background-color: var(--color-background);
  }

  /* Font preview table */
  .font-preview {
    font-size: var(--font-size-lg);
    color: var(--color-accent);
  }

  .font-meta {
    font-size: var(--font-size-sm);
  }

  /* Font sizes table */
  .font-size-preview {
    color: var(--color-accent);
    font-family: var(--font-prose);
    white-space: nowrap;
  }

  /* Letter spacing table */
  .letter-spacing-preview {
    font-family: var(--font-ui);
    text-transform: uppercase;
    font-variant: small-caps;
  }

  /* Font weights table */
  .font-weight-preview {
    font-size: var(--font-size-lg);
    font-family: var(--font-prose);
    white-space: nowrap;
  }
</style>
