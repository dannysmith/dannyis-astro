---
import StyleguideLayout from './_layout/StyleguideLayout.astro';
import DesignTokens from './_DesignTokens.astro';
import UtilityClasses from './_UtilityClasses.astro';
import { ColorSwatch } from '@components/mdx/index';

const toc = [
  { id: 'colour', label: 'Colour System' },
  { id: 'borders', label: 'Borders' },
  { id: 'spacing', label: 'Spacing' },
  { id: 'font-families', label: 'Font families' },
  { id: 'font-sizes', label: 'Font sizes' },
  { id: 'font-weights', label: 'Font weights' },
  { id: 'utility-classes', label: 'Utility classes' },
];

const capitalise = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
---

<StyleguideLayout
  title="Foundations"
  description="The design system documented: colour, design tokens, and utility classes."
  current="foundations"
  toc={toc}
>
  <header>
    <p>
      This page is the primary reference for the site's foundational design system. It includes the
      colour system, the design tokens for spacing, type, borders, radii and shadows, and the global
      utility classes.
    </p>
  </header>

  <section id="colour" class="flow">
    <h2>Colour System</h2>
    <p>
      The colour system is rooted in a set of foundational colours, some of which are <strong
        >adaptive</strong
      > and appear differently in light and dark modes (via <code>light-dark()</code>), and some of
      which are absolute and appear the same in both modes. These are used to create a set of <strong
        >semantic</strong
      > role-based tokens that are primarily used across the site. All colours are defined in <a
        href="https://oklch.com/">OKLCH</a
      >. The adaptive colours use lower lightness and higher chroma in light mode and have increased
      lightness and lower chroma in dark mode.
    </p>
    <div class="sg-panel">
      <div class="sg-swatch-grid" style="--sg-swatch-min: 8rem">
        {
          ['white', 'black', 'ink', 'charcoal', 'beige'].map(colour => (
            <ColorSwatch color={`var(--color-${colour})`} name={capitalise(colour)} />
          ))
        }
      </div>
    </div>
    <div class="sg-theme-pair">
      {
        ['light', 'dark'].map(theme => (
          <div class="sg-theme-col flow" data-theme={theme}>
            <p class="sg-theme-label">{theme} mode</p>
            <div class="sg-swatch-grid">
              {['coral', 'pink', 'orange', 'purple', 'yellow', 'green', 'blue'].map(colour => (
                <ColorSwatch color={`var(--color-${colour})`} name={capitalise(colour)} />
              ))}
            </div>
          </div>
        ))
      }
    </div>
    <p>
      The table below shows the semantic colours currently in use. Components should use these (or
      derivatives of them via CSS functions like `color-mix()`) wherever their use case fits their
      semantic role. In situations where a foundational colour is <em>more semantic</em> (eg a "blue callout")
      then use the foundational colour instead. I deliberately try to keep these semantic colours to a
      minimum to avoid ending up with a large unwieldy palette of very specific colours that are only
      used in one place.
    </p>
    <table>
      <thead>
        <tr>
          <th>Token</th>
          <th class="center">Light</th>
          <th class="center">Dark</th>
          <th>Variable</th>
          <th>Usage</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <th colspan="5">Accent & interaction</th>
        </tr>
        <tr>
          <td>Accent</td>
          <td class="center" data-theme="light">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-accent)" />
            </span>
          </td>
          <td class="center" data-theme="dark">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-accent)" />
            </span>
          </td>
          <td>
            <code>--color-accent</code>
          </td>
          <td>The primary brand colour, used in many places including for links</td>
        </tr>
        <tr>
          <td>Visited</td>
          <td class="center" data-theme="light">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-visited)" />
            </span>
          </td>
          <td class="center" data-theme="dark">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-visited)" />
            </span>
          </td>
          <td>
            <code>--color-visited</code>
          </td>
          <td>Visited links, because purple is an affordance people are used to</td>
        </tr>
        <tr>
          <td>Highlight</td>
          <td class="center" data-theme="light">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-highlight)" />
            </span>
          </td>
          <td class="center" data-theme="dark">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-highlight)" />
            </span>
          </td>
          <td>
            <code>--color-highlight</code>
          </td>
          <td>Highlighted text and occasionally other forms of highlight</td>
        </tr>
        <tr>
          <td>Focus ring</td>
          <td class="center" data-theme="light">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-focus-ring)" />
            </span>
          </td>
          <td class="center" data-theme="dark">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-focus-ring)" />
            </span>
          </td>
          <td>
            <code>--color-focus-ring</code>
          </td>
          <td>The focus ring for interactive elements</td>
        </tr>
      </tbody>
      <tbody>
        <tr>
          <th colspan="5">Backgrounds & surfaces</th>
        </tr>
        <tr>
          <td>Primary background</td>
          <td class="center" data-theme="light">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-background)" />
            </span>
          </td>
          <td class="center" data-theme="dark">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-background)" />
            </span>
          </td>
          <td>
            <code>--color-background</code>
          </td>
          <td>The primary background colour</td>
        </tr>
        <tr>
          <td>Secondary background</td>
          <td class="center" data-theme="light">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-background-secondary)" />
            </span>
          </td>
          <td class="center" data-theme="dark">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-background-secondary)" />
            </span>
          </td>
          <td>
            <code>--color-background-secondary</code>
          </td>
          <td>A secondary background colour for things like cards and panels</td>
        </tr>
        <tr>
          <td>Code background</td>
          <td class="center" data-theme="light">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-background-code)" />
            </span>
          </td>
          <td class="center" data-theme="dark">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-background-code)" />
            </span>
          </td>
          <td>
            <code>--color-background-code</code>
          </td>
          <td>Background for inline code and some other code-like elements</td>
        </tr>
      </tbody>
      <tbody>
        <tr>
          <th colspan="5">Text & borders</th>
        </tr>
        <tr>
          <td>Text</td>
          <td class="center" data-theme="light">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-text)" />
            </span>
          </td>
          <td class="center" data-theme="dark">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-text)" />
            </span>
          </td>
          <td>
            <code>--color-text</code>
          </td>
          <td>Body text</td>
        </tr>
        <tr>
          <td>Text secondary</td>
          <td class="center" data-theme="light">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-text-secondary)" />
            </span>
          </td>
          <td class="center" data-theme="dark">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-text-secondary)" />
            </span>
          </td>
          <td>
            <code>--color-text-secondary</code>
          </td>
          <td>Muted or secondary text</td>
        </tr>
        <tr>
          <td>Border</td>
          <td class="center" data-theme="light">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-border)" />
            </span>
          </td>
          <td class="center" data-theme="dark">
            <span class="sg-mini-swatch">
              <ColorSwatch color="var(--color-border)" />
            </span>
          </td>
          <td>
            <code>--color-border</code>
          </td>
          <td>Subtle borders and dividers</td>
        </tr>
      </tbody>
    </table>
  </section>

  <section id="design-tokens" class="flow">
    <h2>Design tokens</h2>
    <p>
      As with colours, I've tried to keep the number of generic design tokens to a minimum, while
      still providing a wide enough set of options for most use cases.
    </p>

    <h3 id="borders">Borders, radii and shadows</h3>
    <p>
      Five CSS custom properties are available for setting border widths and radii. Border widths
      are set in pixels so they don't scale with the base font size while radii are mostly set in
      rems so they do.
    </p>
    <table>
      <thead>
        <tr>
          <th>Variable</th>
          <th>Value</th>
          <th>Preview</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>--border-width-hairline</code></td>
          <td><code>max(0.0625rem, 1px)</code></td>
          <td>
            <div
              class="border-width-preview"
              style="border-bottom-width: var(--border-width-hairline)"
            >
            </div>
          </td>
          <td
            >1px at the default root size but never falls to a sub-pixel when scaling up with the
            root font size</td
          >
        </tr>
        <tr>
          <td><code>--border-width-base</code></td>
          <td><code>2px</code></td>
          <td>
            <div class="border-width-preview" style="border-bottom-width: var(--border-width-base)">
            </div>
          </td>
          <td>Standard border width for most elements</td>
        </tr>
        <tr>
          <td><code>--border-width-thick</code></td>
          <td><code>4px</code></td>
          <td>
            <div
              class="border-width-preview"
              style="border-bottom-width: var(--border-width-thick)"
            >
            </div>
          </td>
          <td>Usually only applied to one edge of an element</td>
        </tr>
        <tr>
          <td><code>--border-width-heavy</code></td>
          <td><code>6px</code></td>
          <td>
            <div
              class="border-width-preview"
              style="border-bottom-width: var(--border-width-heavy)"
            >
            </div>
          </td>
          <td>Usually only applied to one edge of an element</td>
        </tr>
        <tr>
          <td><code>--border-width-accent</code></td>
          <td><code>1rem</code></td>
          <td>
            <div
              class="border-width-preview"
              style="border-bottom-width: var(--border-width-accent)"
            >
            </div>
          </td>
          <td>Used as a design element, so scales with the root font size</td>
        </tr>
      </tbody>
    </table>
    <table>
      <thead>
        <tr>
          <th>Variable</th>
          <th>Value</th>
          <th>Preview</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>--radius-xs</code></td>
          <td><code>0.125rem</code></td>
          <td><div class="border-radius-preview" style="border-radius: var(--radius-xs)"></div></td>
          <td>Very subtle radius for softening corners slightly</td>
        </tr>
        <tr>
          <td><code>--radius-sm</code></td>
          <td><code>0.25rem</code></td>
          <td><div class="border-radius-preview" style="border-radius: var(--radius-sm)"></div></td>
          <td>Standard radius for most rounded elements</td>
        </tr>
        <tr>
          <td><code>--radius-md</code></td>
          <td><code>0.5rem</code></td>
          <td><div class="border-radius-preview" style="border-radius: var(--radius-md)"></div></td>
          <td></td>
        </tr>
        <tr>
          <td><code>--radius-lg</code></td>
          <td><code>0.75rem</code></td>
          <td><div class="border-radius-preview" style="border-radius: var(--radius-lg)"></div></td>
          <td></td>
        </tr>
        <tr>
          <td><code>--radius-full</code></td>
          <td><code>calc(infinity * 1px)</code></td>
          <td>
            <div class="border-radius-preview" style="border-radius: var(--radius-full)"></div>
          </td>
          <td
            >Infinite radius for fully rounding into a pill or circle regardless of size.</td
          >
        </tr>
      </tbody>
    </table>
    <p>
      I don't use shadows heavily but there are two custom properties available if I need to create depth and elevation.
    </p>
    <table>
      <thead>
        <tr>
          <th>Variable</th>
          <th>Preview</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>--shadow-small</code></td>
          <td class="shadow-preview-container">
            <div class="shadow-preview" style="filter: var(--shadow-small)"></div>
          </td>
        </tr>
        <tr>
          <td><code>--shadow-medium</code></td>
          <td class="shadow-preview-container">
            <div class="shadow-preview" style="filter: var(--shadow-medium)"></div>
          </td>
        </tr>
      </tbody>
    </table>
  </section>

  <DesignTokens />
  <UtilityClasses />
</StyleguideLayout>

<style>
  /* Grid of square colour swatches; --sg-swatch-min controls minimum cell size. */
  .sg-swatch-grid {
    --sg-swatch-min: 6rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(var(--sg-swatch-min), 1fr));
    gap: var(--space-m);
  }

  .sg-swatch-grid :global(.color-swatch) {
    aspect-ratio: 1;
  }

  /* Light/dark comparison: two themed columns side by side. */
  .sg-theme-pair {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(15rem, 100%), 1fr));
    gap: var(--space-s);
  }

  .sg-theme-col {
    padding: var(--space-s);
    border: var(--border-width-hairline) solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .sg-theme-label {
    text-transform: uppercase;
    font-weight: var(--font-weight-medium);
  }

  /* Fixed-size swatch used inside the semantic table cells. */
  .sg-mini-swatch {
    display: inline-block;
    width: 2.5rem;
    height: 2.5rem;
    vertical-align: middle;
  }

  /* Border widths preview */
  .border-width-preview {
    border-bottom-style: solid;
    border-bottom-color: var(--color-accent);
  }

  /* Border radii preview */
  .border-radius-preview {
    width: 5rem;
    height: 3rem;
    background-color: var(--color-accent);
  }

  /* Shadows preview */
  .shadow-preview-container {
    background-color: var(--color-background);
    padding: var(--space-2xs);
  }

  .shadow-preview {
    width: 5rem;
    height: 3rem;
    background-color: var(--color-background);
  }
</style>
