---
import StyleguideLayout from './_layout/StyleguideLayout.astro';
import DesignTokens from './_DesignTokens.astro';
import UtilityClasses from './_UtilityClasses.astro';
import { ColorSwatch } from '@components/mdx/index';

const toc = [
  { id: 'colour', label: 'Colour System' },
  { id: 'spacing', label: 'Spacing' },
  { id: 'border-widths', label: 'Border widths' },
  { id: 'border-radii', label: 'Border radii' },
  { id: 'shadows', label: 'Shadows' },
  { id: 'font-families', label: 'Font families' },
  { id: 'font-sizes', label: 'Font sizes' },
  { id: 'font-weights', label: 'Font weights' },
  { id: 'utility-classes', label: 'Utility classes' },
];

const capitalise = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);

// Semantic colours — role-based tokens, grouped by purpose. These are what you
// reach for in components, rather than the raw palette above.
const semanticGroups = [
  {
    name: 'Accent & interaction',
    tokens: [
      { label: 'Accent', variable: '--color-accent', usage: 'Primary brand colour, links' },
      { label: 'Visited', variable: '--color-visited', usage: 'Visited links' },
      { label: 'Highlight', variable: '--color-highlight', usage: 'Text highlights' },
      { label: 'Focus ring', variable: '--color-focus-ring', usage: 'Focus ring' },
    ],
  },
  {
    name: 'Backgrounds & surfaces',
    tokens: [
      { label: 'Background', variable: '--color-background', usage: 'Page background' },
      {
        label: 'Background secondary',
        variable: '--color-background-secondary',
        usage: 'Cards, panels',
      },
      { label: 'Background code', variable: '--color-background-code', usage: 'Code blocks' },
    ],
  },
  {
    name: 'Text & borders',
    tokens: [
      { label: 'Text', variable: '--color-text', usage: 'Body text' },
      { label: 'Text secondary', variable: '--color-text-secondary', usage: 'Muted text' },
      { label: 'Border', variable: '--color-border', usage: 'Borders, dividers' },
    ],
  },
];
---

<StyleguideLayout
  title="Foundations"
  description="The design system documented: colour, design tokens, and utility classes."
  current="foundations"
  toc={toc}
>
  <header>
    <p>
      This page is the primary reference for the site's foundational design system. It includes the
      colour system, the design tokens for spacing, type, borders, radii and shadows, and the global
      utility classes.
    </p>
  </header>

  <section id="colour" class="flow">
    <h2>Colour System</h2>
    <p>
      The colour system is rooted in a set of foundational colours, some of which are <strong
        >adaptive</strong
      > and appear differently in light and dark modes (via <code>light-dark()</code>), and some of
      which are absolute and appear the same in both modes. These are used to create a set of <strong
        >semantic</strong
      > role-based tokens that are primarily used accross the site. All colors are defined in <a
        href="https://oklch.com/">OKLCH</a
      >. The adaptive colours use lower lightness and higher chroma in light mode and have increased
      lightness and lower chroma in dark mode.
    </p>
    <p></p>
    <div class="sg-theme-pair">
      {
        ['light', 'dark'].map(theme => (
          <div class="sg-theme-col" data-theme={theme}>
            <p class="sg-theme-label">{theme}</p>
            <div class="sg-swatch-grid">
              {['coral', 'pink', 'orange', 'purple', 'yellow', 'green', 'blue'].map(colour => (
                <ColorSwatch color={`var(--color-${colour})`} name={capitalise(colour)} />
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <div class="sg-panel">
      <p class="sg-theme-label">Absolute</p>
      <div class="sg-swatch-grid" style="--sg-swatch-min: 8rem">
        {
          ['white', 'black', 'ink', 'charcoal', 'beige'].map(colour => (
            <ColorSwatch color={`var(--color-${colour})`} name={capitalise(colour)} />
          ))
        }
      </div>
    </div>

    <p>

    </p>
    <table>
      <thead>
        <tr>
          <th>Token</th>
          <th class="center">Light</th>
          <th class="center">Dark</th>
          <th>Variable</th>
          <th>Usage</th>
        </tr>
      </thead>
      {
        semanticGroups.map(({ name, tokens }) => (
          <tbody>
            <tr>
              <th colspan="5">{name}</th>
            </tr>
            {tokens.map(({ label, variable, usage }) => (
              <tr>
                <td>{label}</td>
                <td class="center" data-theme="light">
                  <span class="sg-mini-swatch">
                    <ColorSwatch color={`var(${variable})`} />
                  </span>
                </td>
                <td class="center" data-theme="dark">
                  <span class="sg-mini-swatch">
                    <ColorSwatch color={`var(${variable})`} />
                  </span>
                </td>
                <td>
                  <code>{variable}</code>
                </td>
                <td>{usage}</td>
              </tr>
            ))}
          </tbody>
        ))
      }
    </table>
  </section>

  <DesignTokens />
  <UtilityClasses />
</StyleguideLayout>

<style>
  /* Grid of square colour swatches; --sg-swatch-min controls minimum cell size. */
  .sg-swatch-grid {
    --sg-swatch-min: 6rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(var(--sg-swatch-min), 1fr));
    gap: var(--space-m);
  }

  .sg-swatch-grid :global(.color-swatch) {
    aspect-ratio: 1;
  }

  /* Light/dark comparison: two themed columns side by side. */
  .sg-theme-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-s);
  }

  @media (max-width: 40rem) {
    .sg-theme-pair {
      grid-template-columns: 1fr;
    }
  }

  .sg-theme-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    padding: var(--space-s);
    border: var(--border-width-hairline) solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .sg-theme-label {
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    font-feature-settings: 'case' on;
    color: var(--color-text-secondary);
  }

  /* Fixed-size swatch used inside the semantic table cells. */
  .sg-mini-swatch {
    display: inline-block;
    width: 2.5rem;
    height: 2.5rem;
    vertical-align: middle;
  }
</style>
