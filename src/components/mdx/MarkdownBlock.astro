---
/**
 * MarkdownBlock — renders an included chunk of markdown twice: once as
 * styled prose (default view), once as a source-view code block with the
 * site's Expressive Code treatment. A toggle button switches between the
 * two; a copy button puts the raw markdown on the clipboard.
 *
 * Authors don't use this component directly. They write a standard
 * fenced code block with `md preview` in the meta string:
 *
 *     ```md preview
 *     ## My included markdown
 *     Some text.
 *     ```
 *
 * The `remark-markdown-preview` plugin (src/lib/remark-markdown-preview.mjs)
 * rewrites that code block into a <markdown-preview> JSX element which
 * MDX_COMPONENT_REMAPPING (src/config/mdx-components.ts) maps to this
 * component. The raw markdown is passed in as the `code` prop.
 *
 * Supported meta attributes on the fenced block:
 *   title="README.md"          — optional filename label in the header
 *   defaultView="source"       — show source pane first (defaults to rendered)
 *
 * Progressive enhancement: without JS, the default pane is shown, the
 * other pane is hidden, and the toggle/copy controls are hidden via CSS.
 * Scripts re-initialise after Astro ViewTransitions (`astro:page-load`).
 */
import { Marked } from 'marked';
import { Code } from 'astro-expressive-code/components';

export interface Props {
  /** Raw markdown string to render. */
  code: string;
  /** Optional filename / label shown in the header. */
  title?: string;
  /** Which pane to show first. Defaults to `rendered`. */
  defaultView?: 'rendered' | 'source';
}

const { code, title, defaultView = 'rendered' } = Astro.props;

/** HTML-escape untrusted string values before interpolating into attributes. */
function escapeAttr(value: string): string {
  return value
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

// Fresh Marked instance per render — avoids mutating shared global state
// across concurrent SSR calls, and lets us attach a custom renderer cleanly.
const md = new Marked({ gfm: true, async: false });

// Override marked's link renderer to add security attributes to external
// links. This substitutes for `rehype-external-links`, which only runs on
// the site's main markdown pipeline — included chunks don't pass through
// that pipeline so we handle it here. href/title are escaped defensively
// since we're bypassing marked's default escape.
md.use({
  renderer: {
    link({ href, title: linkTitle, tokens }) {
      // `tokens` is an inline token array for the link text. The parser's
      // parseInline renders them back to (already-escaped) HTML so nested
      // formatting (bold, code, etc.) inside link text is preserved.
      const text = this.parser.parseInline(tokens);
      const isExternal = typeof href === 'string' && /^https?:\/\//i.test(href);
      const hrefAttr = escapeAttr(href ?? '');
      const titleAttr = linkTitle ? ` title="${escapeAttr(linkTitle)}"` : '';
      const securityAttrs = isExternal ? ' target="_blank" rel="noopener noreferrer"' : '';
      return `<a href="${hrefAttr}"${titleAttr}${securityAttrs}>${text}</a>`;
    },
  },
});

const renderedHtml = md.parse(code.trim()) as string;
const showingSource = defaultView === 'source';
---

<figure
  class="md-block"
  data-md-block
  data-view={defaultView}
  aria-label={title ? `Included markdown: ${title}` : 'Included markdown'}
>
  <header class="md-block-header">
    <span class="md-block-label">
      {title ?? 'Markdown'}
    </span>
    <div class="md-block-controls">
      <button
        type="button"
        class="md-block-button"
        data-md-toggle
        aria-pressed={showingSource ? 'true' : 'false'}
      >
        <span class="md-block-toggle-label" data-when="rendered" hidden={showingSource}>
          Source
        </span>
        <span class="md-block-toggle-label" data-when="source" hidden={!showingSource}>
          Preview
        </span>
      </button>
      <button type="button" class="md-block-button" data-md-copy data-md-code={code}>
        Copy
      </button>
    </div>
  </header>

  <div class="md-block-pane md-block-rendered" data-pane="rendered" hidden={showingSource}>
    <div class="longform-prose flow">
      <Fragment set:html={renderedHtml} />
    </div>
  </div>

  <div class="md-block-pane md-block-source" data-pane="source" hidden={!showingSource}>
    <Code code={code} lang="md" wrap />
  </div>
</figure>

<style>
  .md-block {
    margin: var(--space-l) 0;
    border: var(--border-width-hairline) solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-background);
    overflow: hidden;
  }

  .md-block-header {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    padding: var(--space-3xs) var(--space-xs);
    background: var(--color-background-secondary);
    border-bottom: var(--border-width-hairline) solid var(--color-border);
    font-family: var(--font-ui);
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    min-height: calc(var(--space-m) + var(--space-3xs));
  }

  .md-block-label {
    font-family: var(--font-code);
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1 1 auto;
    min-width: 0;
  }

  .md-block-controls {
    display: flex;
    gap: var(--space-3xs);
    flex: 0 0 auto;
  }

  /* Hide controls until JS wires them up — avoids flashing dead buttons. */
  .md-block:not(.md-block-initialized) .md-block-controls {
    visibility: hidden;
  }

  .md-block-button {
    padding: var(--space-3xs) var(--space-2xs);
    font-family: var(--font-ui);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    background: transparent;
    border: var(--border-width-hairline) solid var(--color-border);
    border-radius: var(--radius-xs);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--ease-in-out),
      border-color var(--duration-fast) var(--ease-in-out),
      background-color var(--duration-fast) var(--ease-in-out);
  }

  .md-block-button:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .md-block-button:focus-visible {
    outline: var(--border-width-base) solid var(--color-accent);
    outline-offset: 2px;
  }

  .md-block-button[aria-pressed='true'] {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* Rendered pane gets internal padding; source pane lets Expressive
     Code handle its own padding via its frame chrome. */
  .md-block-rendered {
    padding: var(--space-s) var(--space-m);
  }

  /* Neutralise the longform grid inside this container. The Article
     layout's global rule (`.longform-prose { display: grid; ... }`) would
     otherwise narrow the rendered pane to 60ch with visible gutters,
     which looks inconsistent next to the full-width source pane. */
  .md-block-rendered :global(.longform-prose) {
    display: block;
    grid-template-columns: none;
  }

  .md-block-rendered :global(.longform-prose > *) {
    grid-column: auto;
  }

  /* Neutralise the end-mark decoration that the longform prose normally
     stamps on the final paragraph — it's strange stamped on an included
     chunk that isn't the end of the article. */
  .md-block-rendered :global(.longform-prose > p:last-of-type::after) {
    content: none;
  }

  /* Let Expressive Code's frame sit flush inside the box. */
  .md-block-source :global(.expressive-code) {
    margin: 0;
  }

  .md-block-source :global(.expressive-code .frame) {
    border: none;
    border-radius: 0;
  }

  /* Hide the pane that isn't active. The `hidden` attribute handles the
     initial SSR state; this rule keeps it hidden after JS toggles. */
  .md-block-pane[hidden] {
    display: none;
  }
</style>

<script>
  class MarkdownBlock {
    private static readonly COPY_LABEL = 'Copy';
    private static readonly COPIED_LABEL = 'Copied';
    private static readonly COPY_RESET_MS = 1500;

    private copyResetTimer: number | null = null;

    /**
     * Construct only after all required elements are known to exist. Use
     * {@link MarkdownBlock.init} to attach to a DOM node — it returns null
     * if the node is missing any of the expected children.
     */
    private constructor(
      private readonly el: HTMLElement,
      private readonly toggleBtn: HTMLButtonElement,
      private readonly copyBtn: HTMLButtonElement,
      private readonly renderedPane: HTMLElement,
      private readonly sourcePane: HTMLElement,
      private readonly toggleLabels: HTMLElement[]
    ) {
      this.toggleBtn.addEventListener('click', () => this.toggle());
      this.copyBtn.addEventListener('click', () => this.copy());
      this.el.classList.add('md-block-initialized');
    }

    static init(el: HTMLElement): MarkdownBlock | null {
      const toggleBtn = el.querySelector<HTMLButtonElement>('[data-md-toggle]');
      const copyBtn = el.querySelector<HTMLButtonElement>('[data-md-copy]');
      const renderedPane = el.querySelector<HTMLElement>('[data-pane="rendered"]');
      const sourcePane = el.querySelector<HTMLElement>('[data-pane="source"]');
      if (!toggleBtn || !copyBtn || !renderedPane || !sourcePane) return null;

      const toggleLabels = Array.from(
        el.querySelectorAll<HTMLElement>('.md-block-toggle-label')
      );
      return new MarkdownBlock(el, toggleBtn, copyBtn, renderedPane, sourcePane, toggleLabels);
    }

    private toggle() {
      const nextView = this.el.dataset.view === 'source' ? 'rendered' : 'source';
      this.el.dataset.view = nextView;

      const showingSource = nextView === 'source';
      this.renderedPane.toggleAttribute('hidden', showingSource);
      this.sourcePane.toggleAttribute('hidden', !showingSource);
      this.toggleBtn.setAttribute('aria-pressed', showingSource ? 'true' : 'false');

      this.toggleLabels.forEach(label => {
        label.toggleAttribute('hidden', label.dataset.when !== nextView);
      });
    }

    private async copy() {
      const code = this.copyBtn.dataset.mdCode;
      if (!code) return;

      try {
        await navigator.clipboard.writeText(code);
      } catch (err) {
        console.error('MarkdownBlock: failed to copy markdown:', err);
        return;
      }

      // Brief in-button feedback. Cancel any pending reset so that a
      // rapid second click doesn't leave the button stuck saying "Copied".
      if (this.copyResetTimer !== null) {
        window.clearTimeout(this.copyResetTimer);
      }
      this.copyBtn.textContent = MarkdownBlock.COPIED_LABEL;
      this.copyResetTimer = window.setTimeout(() => {
        this.copyBtn.textContent = MarkdownBlock.COPY_LABEL;
        this.copyResetTimer = null;
      }, MarkdownBlock.COPY_RESET_MS);
    }
  }

  function initMarkdownBlocks() {
    document
      .querySelectorAll<HTMLElement>('[data-md-block]:not(.md-block-initialized)')
      .forEach(el => MarkdownBlock.init(el));
  }

  initMarkdownBlocks();
  document.addEventListener('astro:page-load', initMarkdownBlocks);
</script>
