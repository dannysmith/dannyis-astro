---
/**
 * TabItem - A single tab panel for use within <Tabs>
 *
 * Usage:
 *   <Tabs>
 *     <TabItem label="First">Content here</TabItem>
 *     <TabItem label="Second">More content</TabItem>
 *   </Tabs>
 *
 * Emits only the `data-tab-label` marker plus its content. The WAI-ARIA
 * roles/state (role, id, aria-labelledby, hidden, tabindex) are wired at
 * build time by `@lib/tabs/process-panels`, which `<Tabs>` runs over the
 * rendered slot. Any markdown / MDX / `.astro` content works in here exactly
 * as it would outside a tab — it's already rendered to HTML before processing.
 */
export interface Props {
  label: string;
}

const { label } = Astro.props;
---

<div data-tab-label={label}>
  <slot />
</div>
