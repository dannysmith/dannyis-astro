---
// Import the fonts and global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '@fontsource-variable/fira-code/index.css';
import '../../styles/global.css';

// Import SEO utilities and configuration
import {
  generatePageTitle,
  generateMetaDescription,
  generateJSONLD,
  generateArticleMeta,
  generateOGImageUrl,
  validateSEOData,
} from '@utils/seo';
import { getConfig } from '@config/config';
import { getOgImageUrlForPath } from '@config/og-images';

interface Props {
  title: string;
  description?: string;
  image?: string; // If provided, use as OG image. Otherwise, use default static image.
  type?: 'website' | 'article'; // 'website' (default) or 'article'
  pageType?: 'article' | 'note' | 'page'; // For title template differentiation
  // Optional props that may be passed by article/note layouts
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  // Override the global robots directive (e.g. "noindex" for 404 or playground pages)
  robotsDirective?: string;
  // standard.site (AT Protocol) document AT-URI, for the verification link tag
  // on qualifying article/note pages (see src/utils/standard-site.ts).
  standardSiteDocumentUri?: string;
}

const config = getConfig();
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const robotsDirective = Astro.props.robotsDirective ?? config.seo.robotsDirective;
const isHomepage = Astro.url.pathname === '/';
const { standardSiteDocumentUri } = Astro.props;

// Validate and extract props
const seoData = validateSEOData(Astro.props);

// Generate all SEO values using utilities
const pageTitle = generatePageTitle(seoData.title, seoData.pageType);
const metaDescription = generateMetaDescription(seoData.description);
// Articles/notes pass an explicit `image`. Otherwise, standalone pages
// registered in og-images.ts get their generated cover; everything else
// (home, utility pages) falls back to the static default.
const pageOgImage = getOgImageUrlForPath(Astro.url.pathname);
const ogImageUrl = generateOGImageUrl(seoData.image ?? pageOgImage, Astro.url.toString());
const jsonLD = generateJSONLD(seoData, canonicalURL.toString(), ogImageUrl);
const articleMeta = generateArticleMeta(seoData);
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Font preloads (keep filenames in sync with @font-face in src/styles/_foundation.css). Literata (long-form prose) only on articles. -->
<link
  rel="preload"
  href="/fonts/Figtree-v2.002-2026-04-09.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/Geist-v1.800-2026-04-09.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
{
  Astro.props.pageType === 'article' && (
    <link
      rel="preload"
      href="/fonts/Literata-v3.103-2026-01-19.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  )
}

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Icons -->
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/icon.jpg" />
<link rel="manifest" href="/site.webmanifest" />

<!-- RSS Auto-Discovery -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${config.site.name} - Articles & Notes`}
  href="/rss.xml"
/>
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${config.site.name} - Articles`}
  href="/rss/articles.xml"
/>
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${config.site.name} - Notes`}
  href="/rss/notes.xml"
/>

<!-- standard.site (AT Protocol) verification: document link tag on qualifying
     posts, publication link tag on the homepage. See src/utils/standard-site.ts. -->
{standardSiteDocumentUri && <link rel="site.standard.document" href={standardSiteDocumentUri} />}
{
  isHomepage && config.standardSite.publicationUri && (
    <link rel="site.standard.publication" href={config.standardSite.publicationUri} />
  )
}

<!-- Identity etc -->
<link rel="pgpkey" href="/key.txt" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{pageTitle}</title>
<meta name="title" content={pageTitle} />
<meta name="description" content={metaDescription} />
<meta name="author" content={config.author.fullName} />
<meta name="robots" content={robotsDirective} />
<meta name="theme-color" content={config.site.themeColor} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={seoData.type} />
<meta property="og:site_name" content={config.site.shortName} />
<meta property="og:locale" content={config.site.locale} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={metaDescription} />
<meta property="og:image" content={ogImageUrl} />

<!-- Article-specific OpenGraph meta tags -->
{articleMeta.map(meta => <meta property={meta.property} content={meta.content} />)}

<!-- Twitter -->
<meta property="twitter:card" content={config.seo.twitterCardType} />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={pageTitle} />
<meta property="twitter:description" content={metaDescription} />
<meta property="twitter:image" content={ogImageUrl} />

<!-- Mastodon etc -->
<meta name="fediverse:creator" content={config.author.fediverse} />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLD)} />

<!-- Theme script: inline + render-blocking so the correct theme is set before first paint (no flash) -->
<script is:inline>
  (function () {
    const root = document.documentElement;
    const mq = matchMedia('(prefers-color-scheme: dark)');

    // Saved preference: 'light' | 'dark' | 'auto' (the default when unset or storage is unavailable).
    const current = () => {
      try {
        return localStorage.getItem('theme') || 'auto';
      } catch {
        return 'auto';
      }
    };

    // 'auto' follows the OS; an explicit choice wins.
    const resolve = theme => (theme === 'auto' ? (mq.matches ? 'dark' : 'light') : theme);

    // colorScheme drives the CSS (light-dark() reads it); data-theme is a styling/debug hook.
    const apply = theme => {
      const resolved = resolve(theme);
      root.dataset.theme = root.style.colorScheme = resolved;
      return resolved;
    };

    const set = theme => {
      if (theme !== 'auto' && theme !== 'light' && theme !== 'dark') return;
      try {
        localStorage.setItem('theme', theme);
      } catch {
        // ignore unavailable storage
      }
      const resolvedTheme = apply(theme);
      document.dispatchEvent(new CustomEvent('theme-changed', { detail: { theme, resolvedTheme } }));
    };

    // Public API consumed by ThemeToggle.
    window.theme = {
      get current() {
        return current();
      },
      set,
    };

    apply(current());
    mq.addEventListener('change', () => current() === 'auto' && apply('auto'));
    document.addEventListener('astro:after-swap', () => apply(current()));
  })();
</script>

<!-- Speculation Rules for faster navigation -->
<!-- Prefetch internal links, prerender article/note pages on user intent -->
<script
  is:inline
  type="speculationrules"
  set:html={JSON.stringify({
    prefetch: [
      {
        where: { href_matches: '/*' },
        eagerness: 'moderate',
      },
    ],
    prerender: [
      {
        where: {
          or: [{ href_matches: '/writing/*' }, { href_matches: '/notes/*' }],
        },
        eagerness: 'moderate',
      },
    ],
  })}
/>

<!-- Simple Analytics - 100% privacy-first analytics  -->
<script is:inline async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
<noscript
  ><img
    src="https://queue.simpleanalyticscdn.com/noscript.gif"
    alt=""
    referrerpolicy="no-referrer-when-downgrade"
  /></noscript
>
